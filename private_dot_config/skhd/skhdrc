hyper - 1 : ~/.bin/spotify-ctl playpause
hyper - 2 : ~/.bin/spotify-ctl next
hyper - 3 : ~/.bin/spotify-ctl previous
hyper - 4 : ~/.bin/spotify-ctl mute
hyper - 5 : ~/.bin/spotify-ctl volup
hyper - 6 : ~/.bin/spotify-ctl voldown
hyper - 8 : ~/.bin/priv_show-the-roro


